---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>
  </header>

  <article>
    {{ content }}
  </article>

  {% if page.related_publications %}
    {% if page.bib_query %}
      {% capture bib_query_string %}@*[category ~= {{ page.bib_query }}]{% endcapture %}      
      <div class="publications">
        <h2>References</h2>
        {% bibliography --query {{ bib_query_string }} %}
      </div>
    {% endif %}
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>


